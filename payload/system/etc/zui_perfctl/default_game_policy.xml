    <AttributeName name = "GameLimitConfig">
        游戏参数配置，用于游戏助手进行CPUGPU限频提频boost。格式如下：
        temp1:小核_大核_超大核_GPU|temp2:小核_大核_超大核_GPU（最多支持4个temp类，以“|”分割）
        均衡模式参数 省电模式参数 野兽模式参数（以“ ”分割）
    </AttributeName>
    <AttributeName name = "UPQLimitConfig">
        UPQ游戏参数配置，在应用支持UPQ时替代均衡模式：
        temp1:小核_大核_超大核_GPU|temp2:小核_大核_超大核_GPU（最多支持4个temp类，以“|”分割）
        UPQ级别1参数 UPQ级别2参数 UPQ级别3参数 UPQ级别4参数 UPQ级别5参数（以“ ”分割）
    </AttributeName>
    <AttributeName name = "BestImageLimitConfig">
        极致画质游戏参数配置，在应用设置极致画质时替代GameLimitConfig：
        temp1:小核_大核_超大核_GPU|temp2:小核_大核_超大核_GPU（最多支持4个temp类，以“|”分割）
        均衡模式参数 省电模式参数 野兽模式参数（以“ ”分割）
    </AttributeName>
    <AttributeName name = "ThermalConfig">
        设置thermal code，供bsp进行不同的thermal策略
    </AttributeName>
    <AttributeName name="AssistentSupport">
        <AttributeValue value="TGPA">
            游戏支持TGPA游戏助手，需要等待游戏连接TAssistent。
        </AttributeValue>
    </AttributeName>
    <AttributeName name="RefreshRate">
        应用/游戏的特殊刷新率要求，在设置中选择智能刷新率后生效
    </AttributeName>
    <AttributeName name="PowerSaveRefreshRate">
        应用/游戏的特殊省电模式刷新率要求，在游戏下拉栏中选择节能模式后生效
    </AttributeName>
</NameDefine>-->

