#!/system/bin/sh

DATA_ROOT=/data/vendor/zui_control
CONTROL_DIR=$DATA_ROOT/zuicontrol
DONE_DIR=$CONTROL_DIR/processed
ZUI_DIR=$DATA_ROOT/zuipp
ZUI_BAKED_DIR=$ZUI_DIR/baked_baseline
ZUI_ACTIVE_DIR=$ZUI_DIR/active
ZUI_STAGING_DIR=$ZUI_DIR/staging
ZUI_LAST_GOOD_DIR=$ZUI_DIR/last_good
ZUI_STATE_DIR=$ZUI_DIR/state
ZUI_OFFICIAL_DIR=$ZUI_DIR/official_original
ASOUL_DIR=$DATA_ROOT/asoul
REFRESH_DIR=$DATA_ROOT/refresh
PERFORMANCE_DIR=$DATA_ROOT/performance
LOG_DIR=$DATA_ROOT/log

LOG_FILE=$LOG_DIR/controld.log
ASOUL_LOG=$LOG_DIR/asoulopt.log
STATUS_FILE=$CONTROL_DIR/status.prop
ADB_REQUEST=$CONTROL_DIR/request.prop
LAST_REQUEST_FILE=$CONTROL_DIR/last_processed_settings_request_text

APP_PACKAGE=com.zui.zuicontrol
APP_SERVICE_COMPONENT=com.zui.zuicontrol/com.zui.zuicontrol.ZuiControlQuickService
SAFE_CENTER_PACKAGE=com.zui.safecenter
SAFE_CENTER_DB=/data/user/0/$SAFE_CENTER_PACKAGE/databases/BlackWhite.db
SAFE_CENTER_KEEPALIVE_FLAG=$DATA_ROOT/safecenter_keepalive_done.flag
SAFE_CENTER_KEEPALIVE_BACKUP_FLAG=$DATA_ROOT/safecenter_keepalive_backup.flag
SAFE_CENTER_KEEPALIVE_LOG=$LOG_DIR/safecenter_keepalive.log
PROP_ZUIPP=zui_control.zuipp
PROP_ASOUL=zui_control.asoul

SYSTEM_GAME_POLICY=/system/etc/game_policy.xml
SYSTEM_PERF_CONFIG=/system/etc/performanceconfig.xml
SYSTEM_ASOPT=/system/etc/asopt.conf
DEFAULT_GAME_POLICY=/system/etc/zui_control/default_game_policy.xml
DEFAULT_PERF_CONFIG=/system/etc/zui_control/default_performanceconfig.xml
DEFAULT_ASOPT=/system/etc/zui_control/default_asopt.conf

BAKED_GAME_POLICY=$ZUI_BAKED_DIR/game_policy.xml
BAKED_PERF_CONFIG=$ZUI_BAKED_DIR/performanceconfig.xml
ACTIVE_GAME_POLICY=$ZUI_ACTIVE_DIR/game_policy.xml
ACTIVE_PERF_CONFIG=$ZUI_ACTIVE_DIR/performanceconfig.xml
STAGING_GAME_POLICY=$ZUI_STAGING_DIR/game_policy.xml
STAGING_PERF_CONFIG=$ZUI_STAGING_DIR/performanceconfig.xml
LAST_GOOD_GAME_POLICY=$ZUI_LAST_GOOD_DIR/game_policy.xml
LAST_GOOD_PERF_CONFIG=$ZUI_LAST_GOOD_DIR/performanceconfig.xml
OFFICIAL_GAME_POLICY=$ZUI_OFFICIAL_DIR/game_policy.xml
OFFICIAL_PERF_CONFIG=$ZUI_OFFICIAL_DIR/performanceconfig.xml
WORK_ASOPT=$ASOUL_DIR/asopt.conf
REFRESH_RULES=$REFRESH_DIR/rules.prop
SYSTEM_REFRESH_PROFILES=/data/system/zui_control/profiles.prop
PERFORMANCE_PROFILES=$PERFORMANCE_DIR/profiles.prop
PERFORMANCE_SUMMARY=$PERFORMANCE_DIR/summary.txt
XML_STATUS_FILE=$ZUI_STATE_DIR/status.prop
XML_LAST_ERROR_FILE=$ZUI_STATE_DIR/last_error.txt
XML_ACTIVE_SHA_FILE=$ZUI_STATE_DIR/active.sha256
XML_VERIFY_FILE=$ZUI_STATE_DIR/verify.txt
ZUIPP_APPLY_LOCK_DIR=$ZUI_STATE_DIR/apply.lock
ZUIPP_LAST_RELOADED_HASH_FILE=$ZUI_STATE_DIR/last_reloaded_hash
ZUI_ENABLED=$ZUI_DIR/enabled.flag
ASOUL_ENABLED=$ASOUL_DIR/enabled.flag

REQ_TEXT_KEY=zui_control_request_text
STATUS_TIME_KEY=zui_control_status_time
STATUS_LAST_KEY=zui_control_status_last
STATUS_TEXT_KEY=zui_control_daemon_status_text
DAEMON_REFRESH_STATE_KEY=zui_control_daemon_refresh_state
PERFORMANCE_PROFILES_KEY=zui_control_performance_profiles_text
PERFORMANCE_SUMMARY_KEY=zui_control_performance_summary
TOP_PACKAGE_KEY=zui_control_top_package
SCENE_EVENT_KEY=zui_control_scene_event_text
ZUIPP_RELOAD_STATE_KEY=zui_control_zuipp_reload_state
ASOUL_HEALTH_KEY=zui_control_asoul_health
XML_STATE_KEY=zui_control_xml_state
LOG_EXPORT_KEY=zui_control_log_export

BASE_REFRESH_RATE=120
REFRESH_OWNER=system
LAST_TOP_APP=
LAST_REFRESH_RATE=
LAST_SETTINGS_REQUEST_TEXT=
LAST_SCENE_EVENT_TEXT=
HEALTH_TICKS=0
SAFE_CENTER_KEEPALIVE_TICKS=0
SAFE_CENTER_KEEPALIVE_ATTEMPTS=0
SAFE_CENTER_KEEPALIVE_MAX_ATTEMPTS=60
SAFE_CENTER_KEEPALIVE_DONE=0
SCENE_TTL_SECONDS=60
LOOP_SLEEP_SECONDS=1

ts() {
    date '+%Y-%m-%d %H:%M:%S'
}

now_seconds() {
    date '+%s'
}

uptime_seconds() {
    awk '{printf "%d\n", $1}' /proc/uptime 2>/dev/null
}

settings_get_clean() {
    value="$(settings get system "$1" 2>/dev/null)"
    if [ "$value" = "null" ]; then
        value=
    fi
    printf '%s\n' "$value"
}

settings_get_secure_clean() {
    value="$(settings get secure "$1" 2>/dev/null)"
    if [ "$value" = "null" ]; then
        value=
    fi
    printf '%s\n' "$value"
}

settings_put_quiet() {
    settings put system "$1" "$2" >/dev/null 2>&1
}

settings_put_secure_quiet() {
    settings put secure "$1" "$2" >/dev/null 2>&1
}

read_file_clean() {
    cat "$1" 2>/dev/null | tr -d '\r\n'
}

log_line() {
    mkdir -p "$LOG_DIR"
    printf '%s %s\n' "$(ts)" "$*" >> "$LOG_FILE"
}

trim_log() {
    [ -s "$LOG_FILE" ] || return 0
    size="$(wc -c < "$LOG_FILE" 2>/dev/null)"
    if [ "${size:-0}" -gt 524288 ]; then
        tail -n 2000 "$LOG_FILE" > "$LOG_FILE.tmp" 2>/dev/null &&
            mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
}

set_status() {
    mkdir -p "$CONTROL_DIR"
    {
        echo "time=$(ts)"
        for line in "$@"; do
            echo "$line"
        done
    } > "$STATUS_FILE"
    chmod 0664 "$STATUS_FILE" 2>/dev/null

    last=
    for line in "$@"; do
        case "$line" in
            last=*) last="${line#last=}" ;;
        esac
    done
    settings_put_quiet "$STATUS_TIME_KEY" "$(ts)"
    settings_put_quiet "$STATUS_LAST_KEY" "$last"
    status_text="$(tr '\n' ';' < "$STATUS_FILE" 2>/dev/null)"
    settings_put_quiet "$STATUS_TEXT_KEY" "$status_text"
}

copy_if_missing() {
    src="$1"
    dst="$2"
    if [ -s "$dst" ]; then
        return 0
    fi
    if [ -s "$src" ]; then
        cp "$src" "$dst" && chmod 0664 "$dst"
    fi
}

file_sha() {
    [ -s "$1" ] || return 1
    sha256sum "$1" 2>/dev/null | awk '{print $1}'
}

same_file_hash() {
    left="$(file_sha "$1")"
    right="$(file_sha "$2")"
    [ -n "$left" ] && [ "$left" = "$right" ]
}

verify_active_matches_staging() {
    if ! same_file_hash "$STAGING_GAME_POLICY" "$ACTIVE_GAME_POLICY"; then
        set_xml_error "promote active game_policy hash does not match staging"
        return 1
    fi
    if ! same_file_hash "$STAGING_PERF_CONFIG" "$ACTIVE_PERF_CONFIG"; then
        set_xml_error "promote active performanceconfig hash does not match staging"
        return 1
    fi
    return 0
}

set_xml_error() {
    mkdir -p "$ZUI_STATE_DIR"
    printf '%s %s\n' "$(ts)" "$*" > "$XML_LAST_ERROR_FILE"
    chmod 0664 "$XML_LAST_ERROR_FILE" 2>/dev/null
    log_line "ZuiPP XML error: $*"
}

clear_xml_error() {
    rm -f "$XML_LAST_ERROR_FILE"
}

write_xml_status_file() {
    mkdir -p "$ZUI_STATE_DIR"
    {
        echo "time=$(ts)"
        for line in "$@"; do
            echo "$line"
        done
        if [ -s "$XML_LAST_ERROR_FILE" ]; then
            echo "last_error=$(cat "$XML_LAST_ERROR_FILE" 2>/dev/null)"
        fi
    } > "$XML_STATUS_FILE"
    chmod 0664 "$XML_STATUS_FILE" 2>/dev/null
}

write_active_sha() {
    mkdir -p "$ZUI_STATE_DIR"
    {
        echo "game_policy=$(file_sha "$ACTIVE_GAME_POLICY")"
        echo "performanceconfig=$(file_sha "$ACTIVE_PERF_CONFIG")"
    } > "$XML_ACTIVE_SHA_FILE"
    chmod 0664 "$XML_ACTIVE_SHA_FILE" 2>/dev/null
}

label_active_xml() {
    for file in "$ACTIVE_GAME_POLICY" "$ACTIVE_PERF_CONFIG"; do
        [ -e "$file" ] || continue
        current_mode="$(stat -c %a "$file" 2>/dev/null | head -n 1)"
        if [ "$current_mode" != "664" ]; then
            chmod 0664 "$file" 2>/dev/null || true
        fi
    done
}

prepare_xml_replace_target() {
    file="$1"
    [ -e "$file" ] || return 0
    chmod 0664 "$file" >/dev/null 2>&1 || true
}

copy_xml_pair_to_dir() {
    src_game="$1"
    src_perf="$2"
    dst_dir="$3"
    label="$4"
    [ -s "$src_game" ] && [ -s "$src_perf" ] || {
        set_xml_error "$label source XML missing"
        return 1
    }
    mkdir -p "$dst_dir"
    prepare_xml_replace_target "$dst_dir/game_policy.xml"
    prepare_xml_replace_target "$dst_dir/performanceconfig.xml"
    game_tmp="$dst_dir/game_policy.xml.tmp"
    perf_tmp="$dst_dir/performanceconfig.xml.tmp"
    rm -f "$game_tmp" "$perf_tmp"
    if cp "$src_game" "$game_tmp" &&
        cp "$src_perf" "$perf_tmp"; then
        chown root:root "$game_tmp" "$perf_tmp" >/dev/null 2>&1 || true
        if chmod 0664 "$game_tmp" "$perf_tmp" &&
            mv "$game_tmp" "$dst_dir/game_policy.xml" &&
            mv "$perf_tmp" "$dst_dir/performanceconfig.xml"; then
            return 0
        fi
    fi
    rm -f "$game_tmp" "$perf_tmp"
    set_xml_error "$label copy failed"
    return 1
}

validate_xml_pair() {
    game="$1"
    perf="$2"
    label="$3"
    if [ ! -s "$game" ] || [ ! -s "$perf" ]; then
        set_xml_error "$label validation failed: missing XML"
        return 1
    fi
    grep -q "AppPolicy" "$game" 2>/dev/null || {
        set_xml_error "$label validation failed: AppPolicy missing"
        return 1
    }
    grep -q "GameLimitConfig" "$perf" 2>/dev/null || {
        set_xml_error "$label validation failed: GameLimitConfig missing"
        return 1
    }
    return 0
}

init_baked_baseline_xml() {
    mkdir -p "$ZUI_BAKED_DIR"
    if [ -s "$BAKED_GAME_POLICY" ] && [ -s "$BAKED_PERF_CONFIG" ]; then
        return 0
    fi
    if copy_xml_pair_to_dir "$SYSTEM_GAME_POLICY" "$SYSTEM_PERF_CONFIG" \
        "$ZUI_BAKED_DIR" "baked baseline"; then
        log_line "ZuiPP baked baseline initialized from current /system/etc"
        return 0
    fi
    if copy_xml_pair_to_dir "$DEFAULT_GAME_POLICY" "$DEFAULT_PERF_CONFIG" \
        "$ZUI_BAKED_DIR" "baked baseline fallback"; then
        log_line "ZuiPP baked baseline initialized from payload template"
        return 0
    fi
    return 1
}

init_active_xml() {
    init_baked_baseline_xml || return 1
    mkdir -p "$ZUI_ACTIVE_DIR" "$ZUI_STAGING_DIR" "$ZUI_LAST_GOOD_DIR" \
        "$ZUI_STATE_DIR" "$ZUI_OFFICIAL_DIR"
    if [ ! -s "$ACTIVE_GAME_POLICY" ] || [ ! -s "$ACTIVE_PERF_CONFIG" ]; then
        copy_xml_pair_to_dir "$BAKED_GAME_POLICY" "$BAKED_PERF_CONFIG" \
            "$ZUI_STAGING_DIR" "active init" || return 1
        promote_staging_with_lock "active_init" || return 1
        log_line "ZuiPP active XML initialized from baked baseline"
    fi
    validate_xml_pair "$ACTIVE_GAME_POLICY" "$ACTIVE_PERF_CONFIG" "active" || return 1
    if [ ! -s "$LAST_GOOD_GAME_POLICY" ] || [ ! -s "$LAST_GOOD_PERF_CONFIG" ]; then
        copy_xml_pair_to_dir "$ACTIVE_GAME_POLICY" "$ACTIVE_PERF_CONFIG" \
            "$ZUI_LAST_GOOD_DIR" "last_good init" || return 1
        log_line "ZuiPP last_good initialized from active XML"
    fi
    label_active_xml
    write_active_sha
    return 0
}

valid_package_name() {
    pkg="$1"
    case "$pkg" in
        ""|.*|*.) return 1 ;;
        *..*) return 1 ;;
        *[!A-Za-z0-9_.]*) return 1 ;;
    esac
    return 0
}

valid_refresh_rate() {
    case "$1" in
        60|90|120|144|165) return 0 ;;
    esac
    return 1
}

valid_game_policy_mode() {
    case "$1" in
        independent|default) return 0 ;;
    esac
    return 1
}

valid_game_policy_refresh_rate() {
    case "$1" in
        0|60|90|120|144|165) return 0 ;;
    esac
    return 1
}

valid_game_policy_power_save_refresh_rate() {
    case "$1" in
        0|30|60|90|120|144|165) return 0 ;;
    esac
    return 1
}

valid_frame_policy() {
    case "$1" in
        default|fixed60|follow_display) return 0 ;;
    esac
    return 1
}

legacy_frame_policy() {
    legacy_policy="$1"
    legacy_refresh="$2"
    legacy_power_save="$3"
    if [ "$legacy_policy" != "independent" ]; then
        echo "default"
    elif [ "$legacy_refresh" = "60" ] && [ "$legacy_power_save" = "60" ]; then
        echo "fixed60"
    elif [ -n "$legacy_refresh" ] && [ "$legacy_refresh" != "0" ] &&
        [ "$legacy_refresh" != "$BASE_REFRESH_RATE" ]; then
        echo "follow_display"
    else
        echo "default"
    fi
}

valid_mode() {
    case "$1" in
        balanced|powersave|savage) return 0 ;;
    esac
    return 1
}

valid_stage_payload() {
    [ -n "$1" ] || return 1
    awk -v payload="$1" '
        BEGIN {
            if (payload !~ /^[-0-9,;]+$/) {
                exit 1
            }
            count = split(payload, stages, ";")
            if (count < 1) {
                exit 1
            }
            previous = 0
            for (i = 1; i <= count; i++) {
                if (stages[i] == "") {
                    exit 1
                }
                fields = split(stages[i], values, ",")
                if (fields != 11 || values[1] !~ /^-?[0-9]+$/) {
                    exit 1
                }
                thermal = values[1] + 0
                if (i == 1) {
                    if (thermal != -1000) {
                        exit 1
                    }
                } else {
                    if (thermal < 1 || thermal > 16 || thermal <= previous) {
                        exit 1
                    }
                    previous = thermal
                }
                for (j = 2; j <= 11; j++) {
                    if (values[j] !~ /^[0-9]+$/ || values[j] + 0 <= 0) {
                        exit 1
                    }
                }
                if ((values[2] + 0) < (values[3] + 0) ||
                    (values[4] + 0) < (values[5] + 0) ||
                    (values[6] + 0) < (values[7] + 0) ||
                    (values[8] + 0) < (values[9] + 0) ||
                    (values[10] + 0) < (values[11] + 0)) {
                    exit 1
                }
            }
            exit 0
        }
    '
}

valid_positive_int() {
    case "$1" in
        ""|*[!0-9]*) return 1 ;;
    esac
    [ "$1" -gt 0 ]
}

rewrite_performance_without_key() {
    pkg="$1"
    mode="$2"
    tmp="$PERFORMANCE_PROFILES.tmp"
    : > "$tmp"
    if [ -s "$PERFORMANCE_PROFILES" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            old_ifs="$IFS"
            IFS='|'
            set -- $line
            IFS="$old_ifs"
            line_pkg="$1"
            line_mode="$2"
            if [ "$line_pkg" = "$pkg" ] && [ "$line_mode" = "$mode" ]; then
                continue
            fi
            echo "$line" >> "$tmp"
        done < "$PERFORMANCE_PROFILES"
    fi
    mv "$tmp" "$PERFORMANCE_PROFILES"
    chmod 0664 "$PERFORMANCE_PROFILES" 2>/dev/null
}

migrate_refresh_rules() {
    tmp="$REFRESH_RULES.migrate"
    : > "$tmp"
    if [ -s "$REFRESH_RULES" ]; then
        while IFS='=' read -r pkg rate; do
            valid_package_name "$pkg" || continue
            valid_refresh_rate "$rate" || continue
            [ "$rate" = "$BASE_REFRESH_RATE" ] && continue
            printf '%s=%s\n' "$pkg" "$rate" >> "$tmp"
        done < "$REFRESH_RULES"
    fi
    mv "$tmp" "$REFRESH_RULES"
    chmod 0664 "$REFRESH_RULES" 2>/dev/null
}

publish_refresh_state() {
    settings_put_quiet "$DAEMON_REFRESH_STATE_KEY" "refresh_owner=$REFRESH_OWNER; daemon refresh disabled"
}

publish_performance_state() {
    profiles_text=
    if [ -s "$PERFORMANCE_PROFILES" ]; then
        profiles_text="$(grep -v '^[[:space:]]*#' "$PERFORMANCE_PROFILES" 2>/dev/null |
            grep -v '^[[:space:]]*$' 2>/dev/null)"
    fi
    settings_put_quiet "$PERFORMANCE_PROFILES_KEY" "$profiles_text"
    summary=
    [ -s "$PERFORMANCE_SUMMARY" ] && summary="$(cat "$PERFORMANCE_SUMMARY" 2>/dev/null)"
    settings_put_quiet "$PERFORMANCE_SUMMARY_KEY" "$summary"
}

clear_performance_summary() {
    rm -f "$PERFORMANCE_SUMMARY" "$PERFORMANCE_SUMMARY.tmp"
    settings_put_quiet "$PERFORMANCE_SUMMARY_KEY" ""
}

is_mounted_on() {
    target="$1"
    while read -r _ mount_point _; do
        [ "$mount_point" = "$target" ] && return 0
    done < /proc/mounts
    return 1
}

mount_source_for_target() {
    target="$1"
    awk -v wanted="$target" '$2 == wanted {print $1; exit}' /proc/mounts 2>/dev/null
}

begin_zuipp_verify_file() {
    mkdir -p "$ZUI_STATE_DIR"
    : > "$XML_VERIFY_FILE"
    chmod 0664 "$XML_VERIFY_FILE" 2>/dev/null
    {
        echo "active_game_policy=$(file_sha "$ACTIVE_GAME_POLICY")"
        echo "active_performanceconfig=$(file_sha "$ACTIVE_PERF_CONFIG")"
        echo "system_game_policy=$(file_sha "$SYSTEM_GAME_POLICY")"
        echo "system_performanceconfig=$(file_sha "$SYSTEM_PERF_CONFIG")"
        echo "game_policy_mount_source=$(mount_source_for_target "$SYSTEM_GAME_POLICY")"
        echo "performanceconfig_mount_source=$(mount_source_for_target "$SYSTEM_PERF_CONFIG")"
    } >> "$XML_VERIFY_FILE"
}

verify_zuipp_mount_core() {
    begin_zuipp_verify_file
    if ! is_mounted_on "$SYSTEM_GAME_POLICY" ||
        ! is_mounted_on "$SYSTEM_PERF_CONFIG"; then
        set_xml_error "active bind missing in /proc/mounts"
        write_xml_status_file "mounted=false" "active_hash=$(file_sha "$ACTIVE_GAME_POLICY")"
        return 1
    fi
    if ! same_file_hash "$ACTIVE_GAME_POLICY" "$SYSTEM_GAME_POLICY"; then
        set_xml_error "system game_policy hash does not match active"
        write_xml_status_file "mounted=true" "game_policy=mismatch"
        return 1
    fi
    if ! same_file_hash "$ACTIVE_PERF_CONFIG" "$SYSTEM_PERF_CONFIG"; then
        set_xml_error "system performanceconfig hash does not match active"
        write_xml_status_file "mounted=true" "performanceconfig=mismatch"
        return 1
    fi
    return 0
}

system_xml_contexts_ok() {
    for file in "$SYSTEM_GAME_POLICY" "$SYSTEM_PERF_CONFIG"; do
        context="$(ls -Z "$file" 2>/dev/null | awk '{print $1}')"
        if [ "$context" != "u:object_r:system_file:s0" ]; then
            return 1
        fi
    done
    return 0
}

verify_system_xml_contexts() {
    for file in "$SYSTEM_GAME_POLICY" "$SYSTEM_PERF_CONFIG"; do
        context="$(ls -Z "$file" 2>/dev/null | awk '{print $1}')"
        if [ "$context" != "u:object_r:system_file:s0" ]; then
            set_xml_error "$file context mismatch: $context"
            return 1
        fi
    done
    return 0
}

verify_zuipp_mounts() {
    verify_zuipp_mount_core || return 1
    verify_system_xml_contexts || return 1
    clear_xml_error
    write_active_sha
    write_xml_status_file \
        "mounted=true" \
        "game_policy=$(file_sha "$ACTIVE_GAME_POLICY")" \
        "performanceconfig=$(file_sha "$ACTIVE_PERF_CONFIG")" \
        "source=active"
    return 0
}

publish_xml_state() {
    game_hash="$(file_sha "$ACTIVE_GAME_POLICY")"
    perf_hash="$(file_sha "$ACTIVE_PERF_CONFIG")"
    if is_mounted_on "$SYSTEM_GAME_POLICY" && is_mounted_on "$SYSTEM_PERF_CONFIG" &&
        same_file_hash "$ACTIVE_GAME_POLICY" "$SYSTEM_GAME_POLICY" &&
        same_file_hash "$ACTIVE_PERF_CONFIG" "$SYSTEM_PERF_CONFIG" &&
        system_xml_contexts_ok; then
        clear_xml_error
        settings_put_quiet "$XML_STATE_KEY" \
            "state=mounted;source=active;game=${game_hash:-unknown};perf=${perf_hash:-unknown}"
        write_xml_status_file "mounted=true" "source=active" \
            "game_policy=${game_hash:-unknown}" "performanceconfig=${perf_hash:-unknown}"
    elif is_mounted_on "$SYSTEM_GAME_POLICY" && is_mounted_on "$SYSTEM_PERF_CONFIG" &&
        same_file_hash "$ACTIVE_GAME_POLICY" "$SYSTEM_GAME_POLICY" &&
        same_file_hash "$ACTIVE_PERF_CONFIG" "$SYSTEM_PERF_CONFIG"; then
        verify_system_xml_contexts >/dev/null 2>&1 || true
        settings_put_quiet "$XML_STATE_KEY" \
            "state=mounted_context_error;source=active;game=${game_hash:-unknown};perf=${perf_hash:-unknown}"
        write_xml_status_file "mounted=false" "source=active-context-error" \
            "game_policy=${game_hash:-unknown}" "performanceconfig=${perf_hash:-unknown}"
    elif [ -s "$ACTIVE_GAME_POLICY" ] && [ -s "$ACTIVE_PERF_CONFIG" ] &&
        same_file_hash "$ACTIVE_GAME_POLICY" "$SYSTEM_GAME_POLICY" &&
        same_file_hash "$ACTIVE_PERF_CONFIG" "$SYSTEM_PERF_CONFIG"; then
        settings_put_quiet "$XML_STATE_KEY" \
            "state=unmounted;source=active_matches_system;game=${game_hash:-unknown};perf=${perf_hash:-unknown}"
        write_xml_status_file "mounted=false" "source=active-matches-system" \
            "game_policy=${game_hash:-unknown}" "performanceconfig=${perf_hash:-unknown}"
    elif [ -s "$BAKED_GAME_POLICY" ] && [ -s "$BAKED_PERF_CONFIG" ]; then
        settings_put_quiet "$XML_STATE_KEY" \
            "state=unmounted;source=baked_or_system;game=${game_hash:-unknown};perf=${perf_hash:-unknown}"
        write_xml_status_file "mounted=false" "source=baked_or_system" \
            "game_policy=${game_hash:-unknown}" "performanceconfig=${perf_hash:-unknown}"
    else
        settings_put_quiet "$XML_STATE_KEY" "state=uninitialized"
        write_xml_status_file "mounted=false" "source=uninitialized"
    fi
}

publish_asoul_health() {
    service_state="$(getprop init.svc.zui_asoulopt 2>/dev/null)"
    pid="$(pidof AsoulOpt 2>/dev/null | awk '{print $1}')"
    domain=
    if [ -n "$pid" ]; then
        domain="$(ps -AZ 2>/dev/null | awk -v wanted="$pid" '$3 == wanted {print $1; exit}')"
    fi
    log_size=0
    [ -f "$ASOUL_LOG" ] && log_size="$(wc -c < "$ASOUL_LOG" 2>/dev/null)"
    health="服务：${service_state:-unknown}
进程：${pid:-未运行}
SELinux：${domain:-未识别}
日志：${log_size:-0} 字节"
    settings_put_quiet "$ASOUL_HEALTH_KEY" "$health"
}

publish_state() {
    publish_refresh_state
    publish_performance_state
    publish_xml_state
    publish_asoul_health
}

grant_app_permissions() {
    pm grant "$APP_PACKAGE" android.permission.POST_NOTIFICATIONS >/dev/null 2>&1
    appops set "$APP_PACKAGE" POST_NOTIFICATION allow >/dev/null 2>&1
    appops set "$APP_PACKAGE" WRITE_SETTINGS allow >/dev/null 2>&1
}

notify_quick_service() {
    am start-foreground-service \
        -a com.zui.zuicontrol.action.REFRESH_NOTIFICATION \
        -n "$APP_SERVICE_COMPONENT" >/dev/null 2>&1 ||
        am startservice -n "$APP_SERVICE_COMPONENT" >/dev/null 2>&1
}

app_apk_path() {
    path="$(pm path "$APP_PACKAGE" 2>/dev/null | head -n 1)"
    path="${path#package:}"
    [ -f "$path" ] || return 1
    printf '%s\n' "$path"
}

safecenter_db_readable() {
    SAFE_CENTER_KEEPALIVE_USE_SU=0
    [ -s "$SAFE_CENTER_DB" ] && return 0
    if command -v su >/dev/null 2>&1 &&
        su -c "[ -s $SAFE_CENTER_DB ]" >/dev/null 2>&1; then
        SAFE_CENTER_KEEPALIVE_USE_SU=1
        return 0
    fi
    return 1
}

run_safecenter_root_cmd() {
    if [ "$SAFE_CENTER_KEEPALIVE_USE_SU" = "1" ]; then
        su -c "$1"
    else
        sh -c "$1"
    fi
}

backup_safecenter_db_once() {
    [ -f "$SAFE_CENTER_KEEPALIVE_BACKUP_FLAG" ] && return 0
    backup="$SAFE_CENTER_DB.bak_zui_control_$(date '+%Y%m%d_%H%M%S')"
    if run_safecenter_root_cmd "cp -p $SAFE_CENTER_DB $backup" >/dev/null 2>&1; then
        printf '%s\n' "$backup" > "$SAFE_CENTER_KEEPALIVE_BACKUP_FLAG"
        chmod 0664 "$SAFE_CENTER_KEEPALIVE_BACKUP_FLAG" 2>/dev/null
        return 0
    fi
    return 1
}

patch_safecenter_keepalive() {
    [ -f "$SAFE_CENTER_KEEPALIVE_FLAG" ] && {
        SAFE_CENTER_KEEPALIVE_DONE=1
        return 0
    }
    safecenter_db_readable || {
        log_line "safecenter keepalive deferred: db missing"
        return 1
    }
    apk="$(app_apk_path)" || {
        log_line "safecenter keepalive deferred: apk missing"
        return 1
    }
    backup_safecenter_db_once || true
    tmp_log="$SAFE_CENTER_KEEPALIVE_LOG.tmp"
    patch_cmd="CLASSPATH=$apk app_process /system/bin com.zui.zuicontrol.SafeCenterKeepAlivePatcher $APP_PACKAGE $SAFE_CENTER_DB"
    if run_safecenter_root_cmd "$patch_cmd" > "$tmp_log" 2>&1; then
        cat "$tmp_log" > "$SAFE_CENTER_KEEPALIVE_LOG" 2>/dev/null
        rm -f "$tmp_log"
        run_safecenter_root_cmd \
            "chown system:system $SAFE_CENTER_DB; chmod 0600 $SAFE_CENTER_DB; restorecon $SAFE_CENTER_DB" \
            >/dev/null 2>&1 || true
        am force-stop "$SAFE_CENTER_PACKAGE" >/dev/null 2>&1 || true
        : > "$SAFE_CENTER_KEEPALIVE_FLAG"
        chmod 0664 "$SAFE_CENTER_KEEPALIVE_FLAG" 2>/dev/null
        SAFE_CENTER_KEEPALIVE_DONE=1
        summary="$(head -n 1 "$SAFE_CENTER_KEEPALIVE_LOG" 2>/dev/null)"
        log_line "safecenter keepalive applied: $summary"
        return 0
    fi
    cat "$tmp_log" > "$SAFE_CENTER_KEEPALIVE_LOG" 2>/dev/null
    rm -f "$tmp_log"
    summary="$(head -n 1 "$SAFE_CENTER_KEEPALIVE_LOG" 2>/dev/null)"
    log_line "safecenter keepalive failed: $summary"
    return 1
}

maybe_patch_safecenter_keepalive() {
    [ "$SAFE_CENTER_KEEPALIVE_DONE" = "1" ] && return 0
    [ -f "$SAFE_CENTER_KEEPALIVE_FLAG" ] && {
        SAFE_CENTER_KEEPALIVE_DONE=1
        return 0
    }
    [ "$SAFE_CENTER_KEEPALIVE_ATTEMPTS" -lt "$SAFE_CENTER_KEEPALIVE_MAX_ATTEMPTS" ] || {
        SAFE_CENTER_KEEPALIVE_DONE=1
        log_line "safecenter keepalive stopped after $SAFE_CENTER_KEEPALIVE_ATTEMPTS attempts"
        return 1
    }
    SAFE_CENTER_KEEPALIVE_ATTEMPTS=$((SAFE_CENTER_KEEPALIVE_ATTEMPTS + 1))
    patch_safecenter_keepalive
}

init_dirs() {
    mkdir -p "$CONTROL_DIR" "$DONE_DIR" "$ZUI_DIR" "$ZUI_BAKED_DIR" \
        "$ZUI_ACTIVE_DIR" "$ZUI_STAGING_DIR" "$ZUI_LAST_GOOD_DIR" \
        "$ZUI_STATE_DIR" "$ZUI_OFFICIAL_DIR" "$ASOUL_DIR" \
        "$REFRESH_DIR" "$PERFORMANCE_DIR" "$LOG_DIR"
    chmod 0775 "$DATA_ROOT" "$CONTROL_DIR" "$DONE_DIR" "$ZUI_DIR" \
        "$ZUI_BAKED_DIR" "$ZUI_ACTIVE_DIR" "$ZUI_STAGING_DIR" \
        "$ZUI_LAST_GOOD_DIR" "$ZUI_STATE_DIR" "$ZUI_OFFICIAL_DIR" \
        "$ASOUL_DIR" "$REFRESH_DIR" "$PERFORMANCE_DIR" "$LOG_DIR" 2>/dev/null
    restorecon_recursive "$DATA_ROOT" >/dev/null 2>&1 || true
    init_active_xml || log_line "ZuiPP XML init failed"
    copy_if_missing "$DEFAULT_ASOPT" "$WORK_ASOPT"
    [ -e "$REFRESH_RULES" ] || : > "$REFRESH_RULES"
    [ -e "$PERFORMANCE_PROFILES" ] || : > "$PERFORMANCE_PROFILES"
    chmod 0664 "$REFRESH_RULES" "$PERFORMANCE_PROFILES" 2>/dev/null
    migrate_refresh_rules
    rm -f "$REFRESH_DIR/enabled.flag"
    grant_app_permissions
}

trigger_init_action() {
    prop="$1"
    value="$2"
    setprop "$prop" idle >> "$LOG_FILE" 2>&1
    sleep 1
    if setprop "$prop" "$value" >> "$LOG_FILE" 2>&1; then
        log_line "init action requested: $prop=$value"
        return 0
    fi
    log_line "init action request failed: $prop=$value"
    return 1
}

wait_mount_state() {
    expected="$1"
    shift
    tries=10
    while [ "$tries" -gt 0 ]; do
        ok=1
        for target in "$@"; do
            if [ "$expected" = "mounted" ]; then
                is_mounted_on "$target" || ok=0
            else
                is_mounted_on "$target" && ok=0
            fi
        done
        [ "$ok" = "1" ] && return 0
        tries=$((tries - 1))
        sleep 1
    done
    return 1
}

zuipp_mount_ready() {
    is_mounted_on "$SYSTEM_GAME_POLICY" &&
        is_mounted_on "$SYSTEM_PERF_CONFIG" &&
        same_file_hash "$ACTIVE_GAME_POLICY" "$SYSTEM_GAME_POLICY" &&
        same_file_hash "$ACTIVE_PERF_CONFIG" "$SYSTEM_PERF_CONFIG" &&
        system_xml_contexts_ok
}

wait_zuipp_mount_ready() {
    tries="${1:-10}"
    while [ "$tries" -gt 0 ]; do
        zuipp_mount_ready && return 0
        tries=$((tries - 1))
        sleep 1
    done
    return 1
}

acquire_zuipp_apply_lock() {
    tries="${1:-30}"
    mkdir -p "$ZUI_STATE_DIR"
    while [ "$tries" -gt 0 ]; do
        if mkdir "$ZUIPP_APPLY_LOCK_DIR" 2>/dev/null; then
            printf '%s\n' "$$" > "$ZUIPP_APPLY_LOCK_DIR/pid" 2>/dev/null || true
            return 0
        fi
        lock_pid="$(read_file_clean "$ZUIPP_APPLY_LOCK_DIR/pid")"
        if [ -n "$lock_pid" ] && [ ! -d "/proc/$lock_pid" ]; then
            rm -f "$ZUIPP_APPLY_LOCK_DIR/pid" 2>/dev/null || true
            rmdir "$ZUIPP_APPLY_LOCK_DIR" 2>/dev/null || true
            continue
        fi
        tries=$((tries - 1))
        sleep 1
    done
    set_xml_error "ZuiPP apply lock busy"
    publish_xml_state
    set_status "daemon=running" "last=apply_zuipp_failed" "reason=apply_lock_busy"
    return 1
}

release_zuipp_apply_lock() {
    rm -f "$ZUIPP_APPLY_LOCK_DIR/pid" 2>/dev/null || true
    rmdir "$ZUIPP_APPLY_LOCK_DIR" 2>/dev/null || true
}

xml_hash_pair() {
    game_hash="$(file_sha "$ACTIVE_GAME_POLICY")"
    perf_hash="$(file_sha "$ACTIVE_PERF_CONFIG")"
    [ -n "$game_hash" ] && [ -n "$perf_hash" ] || return 1
    printf '%s:%s\n' "$game_hash" "$perf_hash"
}

publish_zuipp_reload_state() {
    settings_put_quiet "$ZUIPP_RELOAD_STATE_KEY" "$1"
    log_line "ZuiPP reload state: $1"
}

last_reloaded_hash_pair() {
    [ -s "$ZUIPP_LAST_RELOADED_HASH_FILE" ] || return 1
    read_file_clean "$ZUIPP_LAST_RELOADED_HASH_FILE"
}

remember_reloaded_hash_pair() {
    mkdir -p "$ZUI_STATE_DIR"
    printf '%s\n' "$1" > "$ZUIPP_LAST_RELOADED_HASH_FILE"
    chmod 0664 "$ZUIPP_LAST_RELOADED_HASH_FILE" 2>/dev/null
}

zuipp_pid() {
    pidof com.zui.pp 2>/dev/null | awk '{print $1}'
}

proc_cmdline_clean() {
    tr '\0' '\n' < "/proc/$1/cmdline" 2>/dev/null | head -n 1
}

proc_start_time() {
    awk '{print $22}' "/proc/$1/stat" 2>/dev/null
}

reload_zuipp_if_needed() {
    reason="${1:-xml_apply}"
    zuipp_mount_ready || {
        publish_zuipp_reload_state "state=error;stage=verify_mounted_hash;reason=$reason"
        return 1
    }

    hash_pair="$(xml_hash_pair)" || {
        publish_zuipp_reload_state "state=error;stage=hash_pair;reason=$reason"
        return 1
    }
    game_hash="${hash_pair%%:*}"
    perf_hash="${hash_pair#*:}"
    if [ "$hash_pair" = "$(last_reloaded_hash_pair 2>/dev/null)" ]; then
        publish_zuipp_reload_state "state=skipped;reason=same_hash;game=$game_hash;perf=$perf_hash"
        return 0
    fi

    old_pid="$(zuipp_pid)"
    if [ -z "$old_pid" ]; then
        remember_reloaded_hash_pair "$hash_pair"
        publish_zuipp_reload_state "state=skipped;reason=zuipp_not_running;game=$game_hash;perf=$perf_hash"
        return 0
    fi
    if [ "$(proc_cmdline_clean "$old_pid")" != "com.zui.pp" ]; then
        publish_zuipp_reload_state "state=error;stage=pid_check;reason=cmdline_mismatch;oldPid=$old_pid"
        return 1
    fi
    old_start="$(proc_start_time "$old_pid")"

    if ! kill -TERM "$old_pid" 2>>"$LOG_FILE"; then
        publish_zuipp_reload_state "state=error;stage=sigterm;oldPid=$old_pid;game=$game_hash;perf=$perf_hash"
        return 1
    fi

    tries=20
    while [ "$tries" -gt 0 ]; do
        new_pid="$(zuipp_pid)"
        if [ -n "$new_pid" ] && [ "$(proc_cmdline_clean "$new_pid")" = "com.zui.pp" ]; then
            new_start="$(proc_start_time "$new_pid")"
            if [ "$new_pid" != "$old_pid" ] ||
                { [ -n "$new_start" ] && [ "$new_start" != "$old_start" ]; }; then
                remember_reloaded_hash_pair "$hash_pair"
                publish_zuipp_reload_state "state=done;reason=$reason;oldPid=$old_pid;newPid=$new_pid;game=$game_hash;perf=$perf_hash;needsAppReenter=1"
                return 0
            fi
        fi
        tries=$((tries - 1))
        sleep 1
    done

    publish_zuipp_reload_state "state=error;stage=pid_wait;reason=$reason;oldPid=$old_pid;game=$game_hash;perf=$perf_hash"
    return 1
}

wait_prop_value() {
    prop="$1"
    expected="$2"
    tries="${3:-10}"
    while [ "$tries" -gt 0 ]; do
        [ "$(getprop "$prop" 2>/dev/null)" = "$expected" ] && return 0
        tries=$((tries - 1))
        sleep 1
    done
    return 1
}

stage_xml_pair_from_pair() {
    src_game="$1"
    src_perf="$2"
    label="$3"
    copy_xml_pair_to_dir "$src_game" "$src_perf" "$ZUI_STAGING_DIR" "$label staging" || return 1
    validate_xml_pair "$STAGING_GAME_POLICY" "$STAGING_PERF_CONFIG" "$label staging"
}

mark_zuipp_apply_success() {
    reason="$1"
    touch "$ZUI_ENABLED"
    chmod 0664 "$ZUI_ENABLED" 2>/dev/null
    clear_xml_error
    write_active_sha
    write_xml_status_file \
        "mounted=true" \
        "game_policy=$(file_sha "$ACTIVE_GAME_POLICY")" \
        "performanceconfig=$(file_sha "$ACTIVE_PERF_CONFIG")" \
        "source=active"
    publish_xml_state
    reload_zuipp_if_needed "$reason" || true
    set_status "daemon=running" "last=apply_zuipp_ok" "reason=$reason"
}

remount_active_xml() {
    reason="${1:-manual}"
    validate_zuipp_files || {
        set_status "daemon=running" "last=apply_zuipp_failed" "reason=validate_failed"
        return 1
    }
    label_active_xml
    if trigger_init_action "$PROP_ZUIPP" apply &&
        wait_prop_value "$PROP_ZUIPP" done 10 &&
        wait_zuipp_mount_ready 10 &&
        verify_zuipp_mount_core &&
        verify_system_xml_contexts; then
        mark_zuipp_apply_success "$reason"
        return 0
    fi
    set_xml_error "active bind mount verification failed"
    log_line "ZuiPP active remount failed: prop=$(getprop "$PROP_ZUIPP" 2>/dev/null)"
    publish_xml_state
    set_status "daemon=running" "last=apply_zuipp_failed" "reason=remount_failed"
    return 1
}

promote_staging_with_init() {
    reason="$1"
    validate_xml_pair "$STAGING_GAME_POLICY" "$STAGING_PERF_CONFIG" "staging" || return 1
    if trigger_init_action "$PROP_ZUIPP" promote_active &&
        wait_prop_value "$PROP_ZUIPP" done 10 &&
        verify_active_matches_staging &&
        remount_active_xml "$reason"; then
        return 0
    fi
    set_xml_error "promote active verification failed"
    log_line "ZuiPP promote active failed: prop=$(getprop "$PROP_ZUIPP" 2>/dev/null)"
    publish_xml_state
    return 1
}

promote_staging_with_lock() {
    reason="$1"
    acquire_zuipp_apply_lock || return 1
    promote_staging_with_init "$reason"
    result=$?
    release_zuipp_apply_lock
    return "$result"
}

remount_active_with_lock() {
    reason="$1"
    acquire_zuipp_apply_lock || return 1
    remount_active_xml "$reason"
    result=$?
    release_zuipp_apply_lock
    return "$result"
}

validate_zuipp_files() {
    validate_xml_pair "$ACTIVE_GAME_POLICY" "$ACTIVE_PERF_CONFIG" "active"
}

backup_active_to_last_good() {
    validate_xml_pair "$ACTIVE_GAME_POLICY" "$ACTIVE_PERF_CONFIG" "active" || return 1
    copy_xml_pair_to_dir "$ACTIVE_GAME_POLICY" "$ACTIVE_PERF_CONFIG" \
        "$ZUI_LAST_GOOD_DIR" "last_good backup"
}

rollback_active_xml() {
    reason="$1"
    log_line "rollback active XML: $reason"
    if [ -s "$LAST_GOOD_GAME_POLICY" ] && [ -s "$LAST_GOOD_PERF_CONFIG" ]; then
        stage_xml_pair_from_pair "$LAST_GOOD_GAME_POLICY" "$LAST_GOOD_PERF_CONFIG" \
            "rollback last_good" || return 1
        promote_staging_with_init "rollback_last_good"
        return $?
    fi
    stage_xml_pair_from_pair "$BAKED_GAME_POLICY" "$BAKED_PERF_CONFIG" \
        "rollback baked baseline" || return 1
    promote_staging_with_init "rollback_baked"
}

promote_staging_to_active() {
    acquire_zuipp_apply_lock || return 1
    validate_xml_pair "$STAGING_GAME_POLICY" "$STAGING_PERF_CONFIG" "staging" || {
        release_zuipp_apply_lock
        return 1
    }
    backup_active_to_last_good || {
        release_zuipp_apply_lock
        return 1
    }
    if promote_staging_with_init "promote_staging"; then
        backup_active_to_last_good
        release_zuipp_apply_lock
        return 0
    fi
    rollback_active_xml "promote active failed"
    release_zuipp_apply_lock
    return 1
}

apply_zuipp() {
    reason="${1:-manual}"
    init_active_xml || {
        set_status "daemon=running" "last=apply_zuipp_failed" "reason=init_failed"
        return 1
    }
    validate_zuipp_files || {
        set_status "daemon=running" "last=apply_zuipp_failed" "reason=validate_failed"
        return 1
    }
    remount_active_with_lock "$reason"
}

restore_zuipp() {
    init_active_xml || return 1
    stage_xml_pair_from_pair "$BAKED_GAME_POLICY" "$BAKED_PERF_CONFIG" \
        "restore baked baseline" || {
        set_status "daemon=running" "last=restore_zuipp_failed" "reason=copy_failed"
        return 1
    }
    if ! promote_staging_with_lock "restore_baked_baseline"; then
        rollback_active_xml "restore baked baseline failed"
        set_status "daemon=running" "last=restore_zuipp_failed"
        return 1
    fi
    backup_active_to_last_good
    publish_xml_state
    set_status "daemon=running" "last=restore_baked_baseline"
}

restore_last_good_zuipp() {
    init_active_xml || return 1
    if [ ! -s "$LAST_GOOD_GAME_POLICY" ] || [ ! -s "$LAST_GOOD_PERF_CONFIG" ]; then
        set_xml_error "last_good restore requested but last_good XML is missing"
        publish_xml_state
        set_status "daemon=running" "last=restore_last_good_failed"
        return 1
    fi
    stage_xml_pair_from_pair "$LAST_GOOD_GAME_POLICY" "$LAST_GOOD_PERF_CONFIG" \
        "restore last_good" || return 1
    promote_staging_with_lock "restore_last_good"
}

restore_official_original_zuipp() {
    init_active_xml || return 1
    if [ ! -s "$OFFICIAL_GAME_POLICY" ] || [ ! -s "$OFFICIAL_PERF_CONFIG" ]; then
        set_xml_error "official original restore requested but official_original XML is not saved"
        publish_xml_state
        set_status "daemon=running" "last=restore_official_original_unavailable"
        return 1
    fi
    backup_active_to_last_good || true
    stage_xml_pair_from_pair "$OFFICIAL_GAME_POLICY" "$OFFICIAL_PERF_CONFIG" \
        "restore official original" || return 1
    promote_staging_with_lock "restore_official_original"
}

apply_asoul() {
    [ -s "$WORK_ASOPT" ] || return 1
    if trigger_init_action "$PROP_ASOUL" apply &&
        wait_mount_state mounted "$SYSTEM_ASOPT"; then
        touch "$ASOUL_ENABLED"
        chmod 0664 "$ASOUL_ENABLED" 2>/dev/null
        publish_asoul_health
        return 0
    fi
    return 1
}

restore_asoul() {
    trigger_init_action "$PROP_ASOUL" restore
    wait_mount_state unmounted "$SYSTEM_ASOPT" || true
    rm -f "$ASOUL_ENABLED"
    publish_asoul_health
}

ignore_legacy_refresh_request() {
    legacy_cmd="$1"
    log_line "legacy refresh request ignored: cmd=$legacy_cmd owner=$REFRESH_OWNER"
    set_status "daemon=running" "last=${legacy_cmd}_ignored" "refresh_owner=$REFRESH_OWNER"
}

is_overlay_package() {
    case "$1" in
        com.android.systemui) return 0 ;;
    esac
    return 1
}

is_self_package() {
    [ "$1" = "$APP_PACKAGE" ]
}

is_scene_package() {
    pkg="$1"
    valid_package_name "$pkg" || return 1
    is_overlay_package "$pkg" && return 1
    is_self_package "$pkg" && return 1
    return 0
}

latest_scene_event_pkg() {
    event="$(settings_get_clean "$SCENE_EVENT_KEY")"
    [ -n "$event" ] || return 1
    event_time="${event%%|*}"
    pkg="${event#*|}"
    [ "$pkg" != "$event" ] || return 1
    valid_positive_int "$event_time" || return 1
    is_scene_package "$pkg" || return 1
    event_sec=$((event_time / 1000000000))
    now_boot="$(uptime_seconds)"
    valid_positive_int "$now_boot" || return 1
    age=$((now_boot - event_sec))
    [ "$age" -ge 0 ] && [ "$age" -le "$SCENE_TTL_SECONDS" ] || return 1
    printf '%s\n' "$pkg"
}

active_scene_pkg() {
    pkg="$(settings_get_clean "$TOP_PACKAGE_KEY")"
    if is_scene_package "$pkg"; then
        printf '%s\n' "$pkg"
        return 0
    fi
    pkg="$(latest_scene_event_pkg)" && {
        printf '%s\n' "$pkg"
        return 0
    }
    if is_scene_package "$LAST_TOP_APP"; then
        printf '%s\n' "$LAST_TOP_APP"
        return 0
    fi
    return 1
}

current_scene_pkg() {
    pkg="$(settings_get_clean "$TOP_PACKAGE_KEY")"
    if is_scene_package "$pkg"; then
        printf '%s\n' "$pkg"
        return 0
    fi
    pkg="$(latest_scene_event_pkg)" && {
        printf '%s\n' "$pkg"
        return 0
    }
    return 1
}

apply_scene_package() {
    top="$1"
    source="$2"
    if ! is_scene_package "$top"; then
        return 1
    fi
    if [ "$top" = "$LAST_TOP_APP" ]; then
        return 0
    fi
    LAST_TOP_APP="$top"
    log_line "foreground scene observed: $top source=$source refresh_owner=$REFRESH_OWNER"
}

process_scene_event() {
    event="$(settings_get_clean "$SCENE_EVENT_KEY")"
    if [ -n "$event" ]; then
        LAST_SCENE_EVENT_TEXT="$event"
    fi
    pkg="$(current_scene_pkg)" || return 1
    apply_scene_package "$pkg" system_server
}

scene_event_tick() {
    process_scene_event >/dev/null 2>&1 || true
}

set_performance_profile() {
    profile_pkg="$1"
    profile_mode="$2"
    little_max="$3"
    little_min="$4"
    big_max="$5"
    big_min="$6"
    titan_max="$7"
    titan_min="$8"
    mega_max="$9"
    shift 9
    mega_min="$1"
    gpu_max="$2"
    gpu_min="$3"
    if ! valid_package_name "$profile_pkg" || ! valid_mode "$profile_mode" ||
        ! valid_positive_int "$little_max" || ! valid_positive_int "$little_min" ||
        ! valid_positive_int "$big_max" || ! valid_positive_int "$big_min" ||
        ! valid_positive_int "$titan_max" || ! valid_positive_int "$titan_min" ||
        ! valid_positive_int "$mega_max" || ! valid_positive_int "$mega_min" ||
        ! valid_positive_int "$gpu_max" || ! valid_positive_int "$gpu_min" ||
        [ "$little_max" -lt "$little_min" ] ||
        [ "$big_max" -lt "$big_min" ] ||
        [ "$titan_max" -lt "$titan_min" ] ||
        [ "$mega_max" -lt "$mega_min" ] ||
        [ "$gpu_max" -lt "$gpu_min" ]; then
        log_line "invalid performance profile: $profile_pkg $profile_mode"
        set_status "daemon=running" "last=set_performance_profile_failed" "package=$profile_pkg"
        return 1
    fi
    rewrite_performance_without_key "$profile_pkg" "$profile_mode"
    printf '%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s|%s\n' \
        "$profile_pkg" "$profile_mode" \
        "$little_max" "$little_min" \
        "$big_max" "$big_min" \
        "$titan_max" "$titan_min" \
        "$mega_max" "$mega_min" \
        "$gpu_max" "$gpu_min" \
        >> "$PERFORMANCE_PROFILES"
    chmod 0664 "$PERFORMANCE_PROFILES" 2>/dev/null
    clear_performance_summary
    log_line "performance profile saved: $profile_pkg/$profile_mode"
    if generate_performance_xml && promote_staging_to_active; then
        publish_performance_state
        set_status "daemon=running" "last=set_performance_profile_applied" \
            "package=$profile_pkg" "mode=$profile_mode"
        return 0
    fi
    publish_performance_state
    set_status "daemon=running" "last=set_performance_profile_failed" \
        "package=$profile_pkg" "mode=$profile_mode" "reason=apply_failed"
    return 1
}

set_performance_profile_staged() {
    profile_pkg="$1"
    profile_mode="$2"
    stage_payload="$3"
    profile_policy="$4"
    profile_frame_or_refresh="$5"
    profile_power_save="$6"
    profile_frame_policy=
    if ! valid_package_name "$profile_pkg" || ! valid_mode "$profile_mode" ||
        ! valid_stage_payload "$stage_payload"; then
        log_line "invalid staged performance profile: $profile_pkg $profile_mode"
        set_status "daemon=running" "last=set_performance_profile_failed" "package=$profile_pkg"
        return 1
    fi
    if [ -n "$profile_policy$profile_frame_or_refresh$profile_power_save" ]; then
        profile_policy="${profile_policy:-independent}"
        if ! valid_game_policy_mode "$profile_policy"; then
            log_line "invalid staged policy: $profile_pkg $profile_mode policy=$profile_policy"
            set_status "daemon=running" "last=set_performance_profile_failed" "package=$profile_pkg" "reason=invalid_policy"
            return 1
        fi
        if [ -n "$profile_power_save" ] ||
            printf '%s\n' "$profile_frame_or_refresh" | grep -q '^[0-9][0-9]*$'; then
            profile_refresh="${profile_frame_or_refresh:-0}"
            profile_power_save="${profile_power_save:-0}"
            if ! valid_game_policy_refresh_rate "$profile_refresh" ||
                ! valid_game_policy_power_save_refresh_rate "$profile_power_save"; then
                log_line "invalid staged legacy refresh: $profile_pkg $profile_mode policy=$profile_policy refresh=$profile_refresh powersave=$profile_power_save"
                set_status "daemon=running" "last=set_performance_profile_failed" "package=$profile_pkg" "reason=invalid_policy"
                return 1
            fi
            profile_frame_policy="$(legacy_frame_policy "$profile_policy" "$profile_refresh" "$profile_power_save")"
        else
            profile_frame_policy="${profile_frame_or_refresh:-default}"
            if ! valid_frame_policy "$profile_frame_policy"; then
                log_line "invalid staged frame policy: $profile_pkg $profile_mode policy=$profile_policy frame=$profile_frame_policy"
                set_status "daemon=running" "last=set_performance_profile_failed" "package=$profile_pkg" "reason=invalid_frame_policy"
                return 1
            fi
        fi
        [ "$profile_policy" = "default" ] && profile_frame_policy=default
    fi
    rewrite_performance_without_key "$profile_pkg" "$profile_mode"
    if [ -n "$profile_policy$profile_frame_policy" ]; then
        printf '%s|%s|v4|%s|%s|%s\n' \
            "$profile_pkg" "$profile_mode" "$profile_policy" \
            "$profile_frame_policy" "$stage_payload" \
            >> "$PERFORMANCE_PROFILES"
    else
        printf '%s|%s|v2|%s\n' "$profile_pkg" "$profile_mode" "$stage_payload" \
            >> "$PERFORMANCE_PROFILES"
    fi
    chmod 0664 "$PERFORMANCE_PROFILES" 2>/dev/null
    clear_performance_summary
    log_line "staged performance profile saved: $profile_pkg/$profile_mode"
    if generate_performance_xml && promote_staging_to_active; then
        publish_performance_state
        set_status "daemon=running" "last=set_performance_profile_applied" \
            "package=$profile_pkg" "mode=$profile_mode" "thermal=staged"
        return 0
    fi
    publish_performance_state
    set_status "daemon=running" "last=set_performance_profile_failed" \
        "package=$profile_pkg" "mode=$profile_mode" "reason=apply_failed"
    return 1
}

remove_performance_profile() {
    profile_pkg="$1"
    profile_mode="$2"
    if ! valid_package_name "$profile_pkg" || ! valid_mode "$profile_mode"; then
        set_status "daemon=running" "last=remove_performance_profile_failed"
        return 1
    fi
    rewrite_performance_without_key "$profile_pkg" "$profile_mode"
    clear_performance_summary
    log_line "performance profile removed: $profile_pkg/$profile_mode"
    if generate_performance_xml && promote_staging_to_active; then
        publish_performance_state
        set_status "daemon=running" "last=remove_performance_profile_applied" \
            "package=$profile_pkg" "mode=$profile_mode"
        return 0
    fi
    publish_performance_state
    set_status "daemon=running" "last=remove_performance_profile_failed" \
        "package=$profile_pkg" "mode=$profile_mode" "reason=apply_failed"
    return 1
}

app_apk_path() {
    if [ -n "$zui_control_APK_OVERRIDE" ] &&
        [ -s "$zui_control_APK_OVERRIDE" ]; then
        printf '%s\n' "$zui_control_APK_OVERRIDE"
        return 0
    fi
    pm path "$APP_PACKAGE" 2>/dev/null | sed -n 's/^package://p' | head -n 1
}

performance_profiles_have_entries() {
    [ -s "$PERFORMANCE_PROFILES" ] || return 1
    grep -q '^[[:space:]]*[^#[:space:]]' "$PERFORMANCE_PROFILES" 2>/dev/null
}

generate_performance_xml() {
    init_active_xml || return 1
    mkdir -p "$ZUI_STAGING_DIR"
    rm -f "$PERFORMANCE_SUMMARY"
    profiles_empty=0
    performance_profiles_have_entries || profiles_empty=1
    apk="$(app_apk_path)"
    if [ ! -s "$apk" ]; then
        if [ "$profiles_empty" = "1" ] &&
            stage_xml_pair_from_pair "$BAKED_GAME_POLICY" "$BAKED_PERF_CONFIG" \
                "empty performance profiles fallback"; then
            {
                echo "profiles=0"
                echo "generator=unavailable"
                echo "staging_game_policy=$(file_sha "$STAGING_GAME_POLICY")"
                echo "staging_performanceconfig=$(file_sha "$STAGING_PERF_CONFIG")"
            } > "$PERFORMANCE_SUMMARY"
            chmod 0664 "$STAGING_GAME_POLICY" "$STAGING_PERF_CONFIG" \
                "$PERFORMANCE_SUMMARY" 2>/dev/null
            publish_performance_state
            log_line "performance generator missing; staged baked baseline fallback"
            return 0
        fi
        log_line "XML generator APK missing"
        set_xml_error "XML generator APK missing"
        return 1
    fi
    if CLASSPATH="$apk" app_process /system/bin com.zui.zuicontrol.XmlProfileGenerator \
        "$BAKED_GAME_POLICY" "$BAKED_PERF_CONFIG" "$PERFORMANCE_PROFILES" \
        "$SYSTEM_REFRESH_PROFILES" \
        "$STAGING_GAME_POLICY" "$STAGING_PERF_CONFIG" \
        > "$PERFORMANCE_SUMMARY.tmp" 2>&1; then
        validate_xml_pair "$STAGING_GAME_POLICY" "$STAGING_PERF_CONFIG" "staging" || {
            mv "$PERFORMANCE_SUMMARY.tmp" "$PERFORMANCE_SUMMARY" 2>/dev/null
            publish_performance_state
            return 1
        }
        {
            echo "staging_game_policy=$(file_sha "$STAGING_GAME_POLICY")"
            echo "staging_performanceconfig=$(file_sha "$STAGING_PERF_CONFIG")"
        } >> "$PERFORMANCE_SUMMARY.tmp"
        mv "$PERFORMANCE_SUMMARY.tmp" "$PERFORMANCE_SUMMARY"
        chmod 0664 "$STAGING_GAME_POLICY" "$STAGING_PERF_CONFIG" "$PERFORMANCE_SUMMARY" 2>/dev/null
        publish_performance_state
        log_line "performance XML generated into staging"
        return 0
    fi
    mv "$PERFORMANCE_SUMMARY.tmp" "$PERFORMANCE_SUMMARY" 2>/dev/null
    publish_performance_state
    log_line "performance XML generation failed: $(tail -n 1 "$PERFORMANCE_SUMMARY" 2>/dev/null)"
    return 1
}

sync_xml_refresh() {
    if generate_performance_xml && promote_staging_to_active; then
        publish_performance_state
        set_status "daemon=running" "last=sync_xml_refresh_ok"
        return 0
    fi
    publish_performance_state
    set_status "daemon=running" "last=sync_xml_refresh_failed"
    return 1
}

apply_performance() {
    if generate_performance_xml && promote_staging_to_active; then
        set_status "daemon=running" "last=apply_performance_ok"
        return 0
    fi
    set_status "daemon=running" "last=apply_performance_failed"
    return 1
}

export_logs() {
    publish_state
    export_text="ZuiControl 运行记录
导出时间：$(ts)

[状态]
$(cat "$STATUS_FILE" 2>/dev/null)

[刷新率规则]
$(cat "$REFRESH_RULES" 2>/dev/null)

[性能配置]
$(cat "$PERFORMANCE_PROFILES" 2>/dev/null)

[XML 生成摘要]
$(cat "$PERFORMANCE_SUMMARY" 2>/dev/null)

[ZuiPP 重载]
$(settings_get_clean "$ZUIPP_RELOAD_STATE_KEY")

[AsoulOpt 健康状态]
$(settings_get_clean "$ASOUL_HEALTH_KEY")

[守护服务日志末尾]
$(tail -n 120 "$LOG_FILE" 2>/dev/null)

[AsoulOpt 日志末尾]
$(tail -n 80 "$ASOUL_LOG" 2>/dev/null)"
    settings_put_quiet "$LOG_EXPORT_KEY" "$export_text"
    set_status "daemon=running" "last=export_logs"
}

archive_request() {
    file="$1"
    base="$(basename "$file")"
    stamp="$(date '+%Y%m%d_%H%M%S')"
    mkdir -p "$DONE_DIR"
    mv "$file" "$DONE_DIR/$stamp.$base" 2>/dev/null || rm -f "$file"
}

prop_value() {
    key="$1"
    file="$2"
    sed -n "s/^$key=//p" "$file" 2>/dev/null | tail -n 1 | tr -d '\r'
}

request_field() {
    printf '%s\n' "$1" | cut -d '|' -f "$2"
}

request_field_count() {
    printf '%s\n' "$1" | awk -F '|' 'NR == 1 { print NF; exit }'
}

remember_settings_request() {
    LAST_SETTINGS_REQUEST_TEXT="$1"
    printf '%s\n' "$1" > "$LAST_REQUEST_FILE"
    chmod 0664 "$LAST_REQUEST_FILE" 2>/dev/null
}

handle_request() {
    source="$1"
    cmd="$2"
    rate="$3"
    pkg="$4"
    mode="$5"
    little_max="$6"
    little_min="$7"
    big_max="$8"
    big_min="$9"
    shift 9
    titan_max="$1"
    titan_min="$2"
    mega_max="$3"
    mega_min="$4"
    gpu_max="$5"
    gpu_min="$6"
    log_line "request: $source cmd=$cmd rate=$rate pkg=$pkg mode=$mode"

    result=0
    case "$cmd" in
        status)
            publish_state
            verify_zuipp_mounts >/dev/null 2>&1 || publish_xml_state
            set_status "daemon=running" "last=status"
            ;;
        set_refresh|restore_refresh|remove_refresh_rule)
            ignore_legacy_refresh_request "$cmd"
            result=0
            ;;
        set_performance_profile)
            set_performance_profile "$pkg" "$mode" \
                "$little_max" "$little_min" \
                "$big_max" "$big_min" \
                "$titan_max" "$titan_min" \
                "$mega_max" "$mega_min" \
                "$gpu_max" "$gpu_min"
            result=$?
            ;;
        set_performance_profile_staged) set_performance_profile_staged "$pkg" "$mode" "$rate"; result=$? ;;
        remove_performance_profile) remove_performance_profile "$pkg" "$mode"; result=$? ;;
        apply_performance) apply_performance; result=$? ;;
        sync_xml_refresh) sync_xml_refresh; result=$? ;;
        apply_zuipp) apply_zuipp; result=$? ;;
        restore_zuipp) restore_zuipp; result=$? ;;
        restore_last_good) restore_last_good_zuipp; result=$? ;;
        restore_official_original) restore_official_original_zuipp; result=$? ;;
        apply_asoul) apply_asoul; result=$? ;;
        restore_asoul) restore_asoul; result=$? ;;
        export_logs) export_logs; result=$? ;;
        *)
            log_line "unknown request: $cmd"
            set_status "daemon=running" "last=unknown_request" "cmd=$cmd"
            result=1
            ;;
    esac
    trim_log
    return "$result"
}

process_request_file() {
    file="$1"
    [ -s "$file" ] || return 0
    cpu_max="$(prop_value cpu_max "$file")"
    cpu_min="$(prop_value cpu_min "$file")"
    little_max="$(prop_value little_max "$file")"
    little_min="$(prop_value little_min "$file")"
    big_max="$(prop_value big_max "$file")"
    big_min="$(prop_value big_min "$file")"
    titan_max="$(prop_value titan_max "$file")"
    titan_min="$(prop_value titan_min "$file")"
    mega_max="$(prop_value mega_max "$file")"
    mega_min="$(prop_value mega_min "$file")"
    if [ -n "$cpu_max" ] || [ -n "$cpu_min" ]; then
        little_max="${little_max:-$cpu_max}"
        little_min="${little_min:-$cpu_min}"
        big_max="${big_max:-$cpu_max}"
        big_min="${big_min:-$cpu_min}"
        titan_max="${titan_max:-$cpu_max}"
        titan_min="${titan_min:-$cpu_min}"
        mega_max="${mega_max:-$cpu_max}"
        mega_min="${mega_min:-$cpu_min}"
    fi
    handle_request "$file" \
        "$(prop_value cmd "$file")" \
        "$(prop_value rate "$file")" \
        "$(prop_value package "$file")" \
        "$(prop_value mode "$file")" \
        "$little_max" \
        "$little_min" \
        "$big_max" \
        "$big_min" \
        "$titan_max" \
        "$titan_min" \
        "$mega_max" \
        "$mega_min" \
        "$(prop_value gpu_max "$file")" \
        "$(prop_value gpu_min "$file")"
    archive_request "$file"
}

process_atomic_settings_request() {
    request="$(settings_get_clean "$REQ_TEXT_KEY")"
    if [ -z "$request" ] || [ "$request" = "$LAST_SETTINGS_REQUEST_TEXT" ]; then
        return 0
    fi

    field_count="$(request_field_count "$request")"
    id="$(request_field "$request" 1)"
    cmd="$(request_field "$request" 2)"
    rate="$(request_field "$request" 3)"
    pkg="$(request_field "$request" 4)"
    mode="$(request_field "$request" 5)"
    field6="$(request_field "$request" 6)"
    field7="$(request_field "$request" 7)"
    field8="$(request_field "$request" 8)"
    field9="$(request_field "$request" 9)"
    field10="$(request_field "$request" 10)"
    field11="$(request_field "$request" 11)"
    field12="$(request_field "$request" 12)"
    field13="$(request_field "$request" 13)"
    field14="$(request_field "$request" 14)"
    field15="$(request_field "$request" 15)"

    if [ -z "$id" ] || [ -z "$cmd" ]; then
        log_line "invalid atomic request: missing id/cmd"
        set_status "daemon=running" "last=invalid_request"
        remember_settings_request "$request"
        return 1
    fi

    if [ "$field_count" -gt 15 ]; then
        log_line "invalid atomic request: too many fields cmd=$cmd"
        set_status "daemon=running" "last=invalid_request" "cmd=$cmd"
        remember_settings_request "$request"
        return 1
    fi

    if [ "$cmd" = "set_performance_profile_staged" ]; then
        if [ "$field_count" -ne 5 ] && [ "$field_count" -ne 7 ] && [ "$field_count" -ne 8 ]; then
            log_line "invalid staged request: fields=$field_count"
            set_status "daemon=running" "last=invalid_request" "cmd=$cmd"
            remember_settings_request "$request"
            return 1
        fi
        stage_payload="$rate"
        if [ "$field_count" -eq 7 ]; then
            log_line "request: settings:$id cmd=$cmd pkg=$pkg mode=$mode policy=$field6 frame=$field7"
            set_performance_profile_staged "$pkg" "$mode" "$stage_payload" \
                "$field6" "$field7"
        elif [ "$field_count" -eq 8 ]; then
            log_line "request: settings:$id cmd=$cmd pkg=$pkg mode=$mode policy=$field6 refresh=$field7 powersave=$field8"
            set_performance_profile_staged "$pkg" "$mode" "$stage_payload" \
                "$field6" "$field7" "$field8"
        else
            handle_request "settings:$id" "$cmd" \
                "$stage_payload" "$pkg" "$mode" \
                "" "" "" "" "" "" "" "" "" ""
        fi
        result=$?
        trim_log
        remember_settings_request "$request"
        return "$result"
    fi

    if [ "$cmd" = "set_performance_profile" ] &&
        [ -z "$field10$field11$field12$field13$field14$field15" ]; then
        cpu_max="$field6"
        cpu_min="$field7"
        handle_request "settings:$id" "$cmd" \
            "$rate" "$pkg" "$mode" \
            "$cpu_max" "$cpu_min" \
            "$cpu_max" "$cpu_min" \
            "$cpu_max" "$cpu_min" \
            "$cpu_max" "$cpu_min" \
            "$field8" "$field9"
        result=$?
        remember_settings_request "$request"
        return "$result"
    fi
    handle_request "settings:$id" "$cmd" \
        "$rate" "$pkg" "$mode" \
        "$field6" "$field7" \
        "$field8" "$field9" \
        "$field10" "$field11" \
        "$field12" "$field13" \
        "$field14" "$field15"
    result=$?
    remember_settings_request "$request"
    return "$result"
}

boot_restore() {
    log_line "mounting active ZuiPP XML at boot"
    apply_zuipp "boot_active"
    if [ -f "$ASOUL_ENABLED" ]; then
        log_line "restoring enabled AsoulOpt config bind"
        apply_asoul
    fi
}

init_request_state() {
    if [ -s "$LAST_REQUEST_FILE" ]; then
        LAST_SETTINGS_REQUEST_TEXT="$(cat "$LAST_REQUEST_FILE" 2>/dev/null)"
    fi
}

main_loop() {
    init_dirs
    init_request_state
    log_line "zui_controld v19 start"
    boot_restore
    LAST_REFRESH_RATE="$BASE_REFRESH_RATE"
    log_line "daemon refresh disabled: refresh_owner=$REFRESH_OWNER"
    publish_state
    set_status "daemon=running" "last=init" "refresh_owner=$REFRESH_OWNER"
    notify_quick_service
    maybe_patch_safecenter_keepalive || true

    while true; do
        process_atomic_settings_request
        process_request_file "$ADB_REQUEST"
        scene_event_tick
        if [ "$SAFE_CENTER_KEEPALIVE_DONE" != "1" ]; then
            SAFE_CENTER_KEEPALIVE_TICKS=$((SAFE_CENTER_KEEPALIVE_TICKS + 1))
            if [ "$SAFE_CENTER_KEEPALIVE_TICKS" -ge 20 ]; then
                maybe_patch_safecenter_keepalive || true
                SAFE_CENTER_KEEPALIVE_TICKS=0
            fi
        fi
        HEALTH_TICKS=$((HEALTH_TICKS + 1))
        if [ "$HEALTH_TICKS" -ge 20 ]; then
            publish_asoul_health
            publish_xml_state
            HEALTH_TICKS=0
        fi
        sleep "$LOOP_SLEEP_SECONDS"
    done
}

main_loop
